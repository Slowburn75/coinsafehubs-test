```json
{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "db:generate": {
            "cache": false,
            "env": [
                "DATABASE_URL"
            ]
        },
        "db:push": {
            "cache": false,
            "env": [
                "DATABASE_URL"
            ]
        },
        "db:seed": {
            "cache": false,
            "env": [
                "DATABASE_URL"
            ]
        }
    }
}
```