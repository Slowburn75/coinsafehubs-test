{
    "name": "api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "bun --cwd ../../packages/db run db:generate && tsc",
        "start": "node dist/index.js",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "@orpc/server": "*",
        "@hono/node-server": "^1.13.7",
        "hono": "^4.6.9",
        "@orpc/contract": "*",
        "@repo/db": "workspace:*",
        "@repo/types": "workspace:*",
        "zod": "^3.23.8",
        "jsonwebtoken": "^9.0.2",
        "bcrypt": "^5.1.1",
        "date-fns": "^4.1.0"
    },
    "devDependencies": {
        "@repo/config": "workspace:*",
        "@types/node": "^20.17.6",
        "tsx": "^4.19.1",
        "typescript": "^5.6.3",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/bcrypt": "^5.0.2"
    }
}
